rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      // Safety check: only call get() if authenticated
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (getUserData().role == 'admin' || getUserData().role == 'super_manager');
    }

    function isManager() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'manager';
    }

    function isSuperManager() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'super_manager';
    }

    function isAdminOrManager() {
      return isAdmin() || isManager() || isSuperManager();
    }

    function isTeacher() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'teacher';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isNotBanned() {
      return isAuthenticated() && (!('isBanned' in getUserData()) || getUserData().isBanned == false);
    }

    function isNotRestricted(type) {
      return isAuthenticated() && (!('restrictions' in getUserData()) || !getUserData().restrictions.hasAny([type]));
    }

    function belongsToCollege(collegeId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().collegeId == collegeId;
    }

    function isVerified() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().roleVerified == true;
    }

    function isVerifiedOrAdmin() {
      return isVerified() || isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════
    //  USERS COLLECTION
    // ═══════════════════════════════════════════════════

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roleVerified', 'badges', 'supporterBadge', 'isBanned', 'restrictions']) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || !('onboardingCompleted' in resource.data) || resource.data.onboardingCompleted != true)
      ) || isAdminOrManager()
        // Allow any authenticated user to increment/decrement followersCount on any user (restricted to +/- 1)
        || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount']) && (request.resource.data.followersCount == resource.data.followersCount + 1 || request.resource.data.followersCount == resource.data.followersCount - 1));
      allow delete: if isAdmin();

      // Follow system subcollections
      match /followers/{followerId} {
        allow read: if true;
        allow create, delete: if isAuthenticated() && request.auth.uid == followerId;
      }
      match /following/{followingId} {
        allow read: if true;
        allow create, delete: if isOwner(userId);
      }
      match /savedPosts/{postId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ═══════════════════════════════════════════════════
    //  USERNAMES
    // ═══════════════════════════════════════════════════

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ═══════════════════════════════════════════════════
    //  COLLEGES
    // ═══════════════════════════════════════════════════

    match /colleges/{collegeId} {
      allow read: if true;
      allow create: if isAdminOrManager();
      allow update: if isAdminOrManager() || (isTeacher() && belongsToCollege(collegeId));
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════
    //  CLUBS (Modernized)
    // ═══════════════════════════════════════════════════

    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isAdminOrManager();
      allow update: if isAdminOrManager() || (
        isAuthenticated() && resource.data.createdBy == request.auth.uid
      ) || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)).data.role == 'President'
      );
      allow delete: if isAdminOrManager() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);

      match /members/{userId} {
        allow read: if true;
        allow write: if isAdminOrManager() || (
          isAuthenticated() && 
          exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)).data.role == 'President'
        );
      }

      match /requests/{requestId} {
        allow read: if isAdminOrManager() || isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && request.resource.data.status == "pending";
        allow delete: if isAdminOrManager() || (isAuthenticated() && (request.auth.uid == resource.data.userId || 
          (exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)).data.role == 'President')));
      }

      match /activities/{activityId} {
        allow read: if true;
        allow write: if isAdminOrManager() || (
          isAuthenticated() && 
          exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)).data.role == 'President'
        );
      }
    }

    // ═══════════════════════════════════════════════════
    //  FEED & STORIES
    // ═══════════════════════════════════════════════════

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned() && isNotRestricted('posts') && isVerifiedOrAdmin();
      allow update: if isAuthenticated() && (
        isAdminOrManager() || 
        (isOwner(resource.data.creatorId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'creatorId', 'collegeId'])) || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'reactedBy', 'commentsCount', 'likes', 'likedBy'])
      );
      allow delete: if isAdminOrManager() || isOwner(resource.data.creatorId);
    }

    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned() && isNotRestricted('stories') && isVerifiedOrAdmin();
      allow update: if isAuthenticated() && (
        isAdminOrManager() || 
        (isOwner(resource.data.authorId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'authorId', 'collegeId'])) || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'reactedBy', 'commentsCount', 'inspireCount', 'inspiredBy', 'likes', 'likedBy'])
      );
      allow delete: if isAdminOrManager() || isOwner(resource.data.authorId);
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned() && isVerifiedOrAdmin();
      allow update: if isAuthenticated() && (
        isAdminOrManager() || 
        (isOwner(resource.data.userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'postId'])) || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'reactedBy', 'likes', 'likedBy'])
      );
      allow delete: if isAdminOrManager() || isOwner(resource.data.userId);
    }

    // ═══════════════════════════════════════════════════
    //  GROUPS SYSTEM
    // ═══════════════════════════════════════════════════

    match /groups/{groupId} {
      allow read: if isAuthenticated() && (
        resource.data.privacyType != "secret" ||
        exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)) ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isNotBanned() && isVerifiedOrAdmin();
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == "admin") ||
        (isVerifiedOrAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['memberCount', 'postCount']))
      );
      allow delete: if isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == "admin")
      );

      match /members/{userId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (
          isOwner(userId) ||
          isAdmin() ||
          (exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)) &&
           (get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == "admin" ||
            get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == "moderator"))
        );
      }

      match /requests/{userId} {
        allow read: if isAuthenticated() && (
          isOwner(userId) ||
          isAdmin() ||
          (exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)) &&
           (get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == "admin" ||
            get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == "moderator"))
        );
        allow write: if isAuthenticated() && (
          isOwner(userId) ||
          isAdmin() ||
          (exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)) &&
           (get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == "admin" ||
            get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == "moderator"))
        );
      }
    }

    match /groupPosts/{postId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)))
      );
      allow create: if isAuthenticated() && isNotBanned() && isVerifiedOrAdmin() && (
        exists(/databases/$(database)/documents/groups/$(request.resource.data.groupId)/members/$(request.auth.uid))
      );
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)) && (
          request.resource.data.diff(resource.data).affectedKeys().hasAny(['reactions', 'reactedBy', 'commentsCount', 'poll']) ||
          (isOwner(resource.data.creatorId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['groupId', 'creatorId'])) ||
          (get(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)).data.role == "admin" ||
           get(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)).data.role == "moderator")
        ))
      );
      allow delete: if isAuthenticated() && (
        isAdmin() ||
        isOwner(resource.data.creatorId) ||
        (exists(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)).data.role == "admin" ||
          get(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)).data.role == "moderator"
        ))
      );
    }

    match /groupReports/{reportId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)) &&
         (get(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)).data.role == "admin" ||
          get(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)).data.role == "moderator"))
      );
      allow create: if isAuthenticated() && isNotBanned();
      allow update, delete: if isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)) &&
         (get(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)).data.role == "admin" ||
          get(/databases/$(database)/documents/groups/$(resource.data.groupId)/members/$(request.auth.uid)).data.role == "moderator"))
      );
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow create: if isAdminOrManager();
      allow update: if isAdminOrManager() || (
        isAuthenticated() && resource.data.authorId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['postedBy'])
      );
      allow delete: if isAdminOrManager();
    }

    match /gifts/{giftId} {
      allow read: if true;
      allow create: if isAuthenticated() && isVerifiedOrAdmin();
      allow update: if isAdminOrManager() || (
        isAuthenticated() && resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'photoURL'])
      );
      allow delete: if isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════
    //  GENERAL
    // ═══════════════════════════════════════════════════
    
    match /notifications/{noteId} {
       allow read: if isAuthenticated() && (isAdminOrManager() || resource.data.recipientId == request.auth.uid);
       allow create: if isAuthenticated() && (
         isAdminOrManager() || (
           (!('targetUrl' in request.resource.data) || request.resource.data.targetUrl.matches('^/.*') || request.resource.data.targetUrl == '')
         )
       );
       allow update: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
       allow delete: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
    }
    
    match /pendingEdits/{editId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdminOrManager();
      allow delete: if isAdminOrManager() || isOwner(resource.data.authorId);
    }

    match /linkPreviewCache/{cacheId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════
    //  GLOBAL RESOURCES (Public access on read)
    // ═══════════════════════════════════════════════════
    match /qaCards/{docId} {
      allow read: if true;
      allow write: if isAdminOrManager();
    }
    match /admissionSteps/{docId} {
      allow read: if true;
      allow write: if isAdminOrManager();
    }
    match /admissionCosts/{docId} {
      allow read: if true;
      allow write: if isAdminOrManager();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdminOrManager();
    }
    match /supportPhases/{docId} {
       allow read: if true;
       allow write: if isAdminOrManager();
    }

    match /studyPosts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned() && isVerifiedOrAdmin();
      allow update: if isAuthenticated() && (
        isAdminOrManager() || 
        (isOwner(resource.data.authorId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'authorId', 'collegeId'])) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'reactedBy', 'commentsCount', 'likes', 'likedBy'])
      );
      allow delete: if isAdminOrManager() || isOwner(resource.data.authorId);
    }

    // Default catch-all (safety first)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
